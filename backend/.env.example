# Environment Variables for Lumina Library Manager Backend

# Server Configuration
PORT=5000

# MongoDB Connection String
# Replace with your actual MongoDB Atlas connection string
MONGO_URI=mongodb://username:password@host1:27017,host2:27017,host3:27017/database_name?ssl=true&authSource=admin&replicaSet=replica-set-name

# Example SRV format (if your network supports it):
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority
